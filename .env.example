# =====================================================================
# DigitalEconomy.cloud — Environment Variables
# Copy this file to `.env.local` and fill in real values for local dev.
# In production, set the same variables in Vercel → Project → Settings.
# =====================================================================

# ----- Public site config -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="DigitalEconomy.cloud"

# ----- Supabase (Project Settings → API) -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only key, never expose to the browser. Used by admin server actions.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ----- OAuth providers (configured in Supabase → Authentication → Providers) -----
# Google OAuth client (id + secret are set in Supabase, not here)
# GitHub OAuth app (id + secret are set in Supabase, not here)

# ----- Email (Resend) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL="DigitalEconomy.cloud <hello@digitaleconomy.cloud>"

# ----- Observability (optional but recommended) -----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ----- Feature flags -----
NEXT_PUBLIC_ENABLE_WEB3=false

# ----- Web3 / Phase 2 (only required when NEXT_PUBLIC_ENABLE_WEB3=true) -----
# Default chain for wallet sign-in and minting. One of: "base", "base-sepolia",
# "polygon", "polygon-amoy", "ethereum", "sepolia".
NEXT_PUBLIC_WEB3_CHAIN=base-sepolia
# Optional WalletConnect Cloud project id, used if/when RainbowKit is wired in.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
